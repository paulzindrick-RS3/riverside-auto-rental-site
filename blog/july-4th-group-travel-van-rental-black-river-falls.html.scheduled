#sms-bubble a:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(48,75,120,0.5);}
#sms-bubble svg{flex-shrink:0;}
@media(max-width:768px){#sms-bubble{bottom:72px;right:16px;}}
</style>
